# =============================================================================
# KISWARM6.0 Docker Ignore File
# =============================================================================
# Specifies files and directories to exclude from Docker build context
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Node.js
**/node_modules
**/.pnpm-store
**/.npm
**/.pnpm-debug.log
**/npm-debug.log
**/yarn-error.log
**/yarn.lock

# Python
**/__pycache__
**/*.py[cod]
**/*$py.class
**/.Python
**/.venv
**/venv
**/ENV
**/*.egg-info
**/*.egg
**/.eggs
**/dist
**/build
**/.pytest_cache
**/.mypy_cache
**/.coverage
**/htmlcov

# IDE
.idea
.vscode
*.swp
*.swo
*~
.project
.pydevproject
.settings

# Build outputs
**/dist
**/build
**/.next
**/.nuxt
**/.output

# Logs
logs
*.log
*.log.*

# Environment files
.env
.env.*
!.env.example

# Test files
tests
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
**/*.test.py
**/*.spec.py
coverage

# Documentation
docs
*.md
!README.md
CHANGELOG.md

# Docker
Dockerfile*
docker-compose*.yml
.docker
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci
Jenkinsfile

# Temporary files
tmp
temp
*.tmp
*.temp
*.bak
*.swp

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Uploads and data
uploads
data
*.sqlite
*.db

# Misc
.editorconfig
.prettierrc
.eslintrc*
.prettierrc*
tsconfig*.json

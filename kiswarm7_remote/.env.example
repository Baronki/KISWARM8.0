# =============================================================================
# KISWARM6.0 Environment Configuration Example
# =============================================================================
# Copy this file to .env and configure for your environment
# =============================================================================

# ==================== Application ====================
NODE_ENV=production
VITE_APP_ID=kiswarm6

# ==================== Database ====================
# MySQL connection string
DATABASE_URL=mysql://kiswarm:kiswarm_password@localhost:3306/kiswarm6

# ==================== Authentication ====================
# Generate secure secrets: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-change-me-in-production
KIBANK_SECRET_KEY=your-kibank-secret-key-change-me-in-production

# ==================== API URLs ====================
VITE_KISWARM_API_URL=http://localhost:5001
VITE_TRPC_BRIDGE_URL=http://localhost:3000

# ==================== OAuth (Optional) ====================
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ==================== AI/LLM (Optional) ====================
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ==================== Qdrant Vector DB ====================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ==================== Ports ====================
BACKEND_PORT=5001
FRONTEND_PORT=5173
BRIDGE_PORT=3000

# ==================== Gunicorn (Production) ====================
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=gevent
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0

# ==================== MySQL (Docker) ====================
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_PORT=3306

# ==================== Redis (Optional) ====================
REDIS_PORT=6379

# ==================== Qdrant (Docker) ====================
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ==================== Nginx (Production) ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ==================== Docker Compose ====================
VERSION=6.0.0

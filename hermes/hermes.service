[Unit]
Description=Hermes Agent - KISWARM Autonomous AI
Documentation=https://github.com/Baronki/KISWARM8.0
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hermes
ExecStartPre=/bin/sleep 5
ExecStart=/usr/bin/python3 /opt/hermes/hermes_agent.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

# Environment
Environment="HERMES_CONFIG=/opt/hermes/config.yaml"
Environment="OLLAMA_HOST=http://localhost:11434"
Environment="PYTHONUNBUFFERED=1"

# Resource limits
LimitNOFILE=65536
MemoryMax=8G
CPUQuota=200%

# Security (relaxed for autonomous operation)
PrivateTmp=false
NoNewPrivileges=false

[Install]
WantedBy=multi-user.target
